{
  "kind": "collectionType",
  "collectionName": "blog_posts",
  "info": {
    "singularName": "blog-post",
    "pluralName": "blog-posts",
    "displayName": "Blog Post"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": false
    },
    "excerpt": {
      "type": "text",
      "maxLength": 250
    },
    "content": {
      "type": "blocks"
    },
    "featuredImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "categories": {
      "type": "json"
    },
    "tags": {
      "type": "json"
    },
    "author": {
      "type": "string"
    },
    "readTime": {
      "type": "integer"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "relatedGames": {
      "type": "json"
    }
  }
}
